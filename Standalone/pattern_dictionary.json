  "^(?:<color=[^>]+>)?(?<name>[^:]+?) :: Level (?<lvl>\\d+)\\s*\\[(?<mode>[^\\]]+)\\]?(?:</color>)?\\s*$": "{name} :: Уровень {lvl} [{mode}]",
  "^(?:<color=[^>]+>)?(?<name>[^:]+?) :: Уровень (?<lvl>\\d+)\\s*\\[(?<mode>[^\\]]+)\\]?(?:</color>)?\\s*$": "{name} :: Уровень {lvl} [{mode}]",
  "^(?:<|)?(?:color=[^>]+>)?Whew! You killed the snapjaw and earned some experience\\. It looks like they dropped a piece of equipment, too\\.?[\\s\\n\\r]+Press(?<tail>.*?)(?:</color>)?\\s*$": "Уф! Вы убили снапджава и получили немного опыта. Похоже, с него также выпало снаряжение.\\n\\nНажмите{tail}",
  "^(?:The |A )?(?<attacker>.+) hits (?:you )?for (?<dmg>\\d+) damage with (?:her|his|its|their) (?<weapon>.+?)\\.?$": "{attacker} попадает по вам и наносит {dmg} урона своим {weapon}.",
  "^(?:The |A )?(?<attacker>.+) hits (?:you )?for (?<dmg>\\d+) damage\\.?$": "{attacker} попадает по вам и наносит {dmg} урона.",
  "^You critically hit (?:the |a )?(?<target>.+) for (?<dmg>\\d+) damage with your (?<weapon>.+?)\\!?$": "Вы наносите критический удар по {target} на {dmg} урона вашим {weapon}!",
  "^(?<dmg>[-+]\\d+) to hit in melee combat\\.$": "{dmg} к попаданию в ближнем бою.",
  "^(?<pref>.*?)The (?<enemy>.*?) takes (?<dmg>\\d+) damage from (?<your>your) (?<eff>.*?) effect!(?<suff>.*?)$": "{pref}{enemy} получает {dmg} ед. урона от вашего эффекта: {eff}!{suff}",
  "^(?<pref>.*?)(?<pronoun>You|you) hit (?<roll>.*?) for (?<dmg>\\d+) damage with (?<your>your) (?<weapon>.*?)! \\[(?<dice>.*?)\\](?<suff>.*?)$": "{pref}Вы наносите удар {roll} на {dmg} ед. урона вашим оружием: {weapon}! [{dice}]{suff}",
  "^(?<pref>.*?)You hit (?<target>.*?) for (?<dmg>\\d+) damage with your (?<weapon>.*?)!(?<suff>.*?)$": "{pref}Вы наносите удар по {target} на {dmg} ед. урона вашим оружием: {weapon}!{suff}",
  "^(?<pref>.*?)The (?<enemy>.*?) hits (?<roll>.*?) for (?<dmg>\\d+) damage with (?<pronoun>her|his|its) (?<weapon>.*?)!(?<suff>.*?)$": "{pref}{enemy} наносит удар {roll} на {dmg} ед. урона ({weapon})!{suff}",
  "^(?<pref>.*?)The (?<enemy>.*?) hits (?<roll>.*?) for (?<dmg>\\d+) damage with (?<pronoun>her|his|its) (?<weapon>.*?)\\.(?<suff>.*?)$": "{pref}{enemy} наносит удар {roll} на {dmg} ед. урона ({weapon}).{suff}",
  "^(?<pref>.*?)Bleed save: Toughness (?<val>\\d+)(?<suff>.*?)$": "{pref}Спасбросок от кровотечения: Стойкость {val}{suff}",
