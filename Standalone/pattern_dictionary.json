  "^(?:<color=[^>]+>|color=[^>]+>)?Mutation Points:(?:</color>)?(?:<color=[^>]+>)?\\s*(?<pts>\\d+)(?:</color>)?(?:<color=[^>]+>)?\\s*(?:</color>)?$": "Очки мутаций: {pts}",
