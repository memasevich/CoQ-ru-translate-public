  "^(?<pref>.*?) hits вас for (?<dmg>\\d+) damage with its (?<weapon>.*?)!(?<suff>.*?)$": "{pref} наносит вам {dmg} ед. урона ({weapon})!{suff}",
  "^(?<val>\\d+)lbs\\.(?<suff>.*?)$": "{val} фунт.{suff}",
