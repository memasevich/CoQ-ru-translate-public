  "^You hit (?:the |a )?(?<target>.+) for (?<dmg>\\d+) damage with your (?<weapon>.+)!$": "Вы попали по {target} на {dmg} урона своим {weapon}!",
  "^Level: (?<lvl>\\d+) » HP: (?<hp>\\d+)/(?<maxhp>\\d+) » XP: (?<xp>\\d+)/(?<nextxp>\\d+) » Weight: (?<wt>\\d+)#$": "Уровень: {lvl} » ОЗ: {hp}/{maxhp} » ОПТ: {xp}/{nextxp} » Вес: {wt}#",
  "^Level: (?<lvl>\\d+) » HP: (?<hp>\\d+)/(?<maxhp>\\d+) » XP: (?<xp>\\d+)/(?<nextxp>\\d+) » Weight: (?<wt>\\d+)# » (?<rest>.+)$": "Уровень: {lvl} » ОЗ: {hp}/{maxhp} » ОПТ: {xp}/{nextxp} » Вес: {wt}# » {rest}",
  "^You see a (?<name>.+?) to the (?<dir>.+?) and stop (?:exploring|moving)\\.?$": "Вы видите {name} на {dir} и останавливаетесь.",
